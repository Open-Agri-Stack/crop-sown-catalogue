{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "Location Id": {
            "type": "string",
            "prefix": "location-",
            "key": "Primary",
            "keyLength": 12,
            "description": "location prefix"
        },
        "Region": {
            "type": "string",
            "description": "region the market place belongs to"
        },
        "Market Place": {
            "type": "string",
            "description": "name of the market place"
        }
    },
    "required": [
        "Region",
        "Market Place"
    ]
}
