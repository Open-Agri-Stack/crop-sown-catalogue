{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "Crop Category Id": {
            "type": "string",
            "prefix": "cropcategory-",
            "key": "Primary",
            "keyLength": 5,
            "description": "crop category prefix"
        },
        "Name": {
            "type": "string",
            "description": "name of the crop category"
        },
        "Image Url": {
            "type": "string",
            "description": "image url of the crop category"
        },
        "Description": {
            "type": "string",
            "description": "description of the crop category"
        }

    },
    "required": [
        "Name",
        "Image Url"
    ]
}