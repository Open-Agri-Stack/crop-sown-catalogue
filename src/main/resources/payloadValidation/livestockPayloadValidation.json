{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "Livestock Id": {
            "type": "string",
            "prefix": "livestock-",
            "key": "Primary",
            "keyLength": 12,
            "description": "livestock prefix"
        },
        "Livestock": {
            "type": "string",
            "description": "type of the livestock"
        },
        "Location type": {
            "type": "string",
            "description": "location type of the livestock (e.g. High Land, Low Land); absent when not applicable"
        },
        "Breed": {
            "type": "string",
            "description": "breed of the livestock"
        },
        "Gender": {
            "type": "string",
            "description": "gender of the livestock"
        },
        "Production type": {
            "type": "string",
            "description": "production type of the livestock (e.g. Castrated, Meat, Milk); absent when not applicable"
        },
        "Body condition": {
            "type": "string",
            "description": "body condition of the livestock (e.g. Thin, Moderate Weight, Very Fat)"
        }
    },
    "required": [
        "Livestock",
        "Breed"
    ]
}
